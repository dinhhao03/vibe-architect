erDiagram    Customers ||--o{ Tickets : "submits"    Agents |o--o{ Tickets : "assigns/handles"    Agents ||--o{ TicketNotes : "adds"    Tickets ||--o{ TicketNotes : "has"    TicketStatuses ||--o{ Tickets : "defines"    Customers {        UUID customer_id PK        VARCHAR customer_name        VARCHAR customer_email UNIQUE        TIMESTAMP created_at        TIMESTAMP updated_at    }    Agents {        UUID agent_id PK        VARCHAR agent_name        VARCHAR agent_email UNIQUE        TIMESTAMP created_at        TIMESTAMP updated_at    }    TicketStatuses {        UUID status_id PK        VARCHAR status_name UNIQUE "e.g. New, Open, In Progress, Resolved, Closed"        BOOLEAN is_active DEFAULT TRUE    }    Tickets {        UUID ticket_id PK        UUID customer_id FK        UUID agent_id FK NULL        UUID status_id FK        VARCHAR subject        TEXT description        TIMESTAMP created_at        TIMESTAMP updated_at        TIMESTAMP closed_at NULL    }    TicketNotes {        UUID note_id PK        UUID ticket_id FK        UUID agent_id FK        TEXT note_content        TIMESTAMP created_at    }